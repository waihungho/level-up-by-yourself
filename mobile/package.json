{
  "name": "level-up-by-yourself-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "prebuild:android": "expo prebuild --platform android --clean",
    "ios": "expo run:ios",
    "build:dapp-store": "eas build --profile solana-dapp-store --platform android --local",
    "dapp-store:create": "npx dapp-store create -k ~/.config/solana/level-up-by-youself.json -b https://mainnet.helius-rpc.com",
    "dapp-store:publish": "npx dapp-store publish -k ~/.config/solana/level-up-by-youself.json -b https://mainnet.helius-rpc.com"
  },
  "dependencies": {
    "@solana-mobile/mobile-wallet-adapter-protocol": "^2.2.5",
    "@solana-mobile/mobile-wallet-adapter-protocol-web3js": "^2.2.5",
    "@solana/web3.js": "^1.98.4",
    "expo": "~54.0.32",
    "expo-build-properties": "~1.0.10",
    "expo-crypto": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "^13.12.5"
  },
  "devDependencies": {
    "@solana-mobile/dapp-store-cli": "^0.15.0",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^54.0.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
